generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id                 Int       @id @default(autoincrement())
  nombre             String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  rol                rol?      @default(VENDEDOR) @map("rol")
  porcentajeComision Float?    @default(0) @map("porcentaje_comision")
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  ventas             Venta[]

  @@map("usuarios")
}

model Producto {
  id              Int              @id @default(autoincrement())
  nombre          String           @db.VarChar(255)
  marca           String?          @db.VarChar(255)
  precioMayorista Float            @map("precio_mayorista")
  precioMinorista Float            @map("precio_minorista")
  categoria       String?          @db.VarChar(255)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  imagenes        ProductoImagen[]
  variantes       Variante[]

  @@map("productos")
}

model Variante {
  id            Int            @id @default(autoincrement())
  productoId    Int            @map("producto_id")
  sku           String         @unique @db.VarChar(255)
  color         String?        @db.VarChar(255)
  talla         String         @db.VarChar(255)
  stockActual   Int?           @default(0) @map("stock_actual")
  stockMinimo   Int?           @default(0) @map("stock_minimo")
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  producto      Producto       @relation(fields: [productoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ventaDetalles VentaDetalle[]

  @@index([productoId], map: "idx_variantes_producto")
  @@index([sku], map: "idx_variantes_sku")
  @@map("variantes")
}

model Cliente {
  id        Int       @id @default(autoincrement())
  nombre    String    @db.VarChar(255)
  contacto  String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  ventas    Venta[]

  @@map("clientes")
}

model Venta {
  id                Int            @id @default(autoincrement())
  fecha             DateTime?      @default(now()) @db.Timestamp(6)
  clienteId         Int?           @map("cliente_id")
  vendedorId        Int            @map("vendedor_id")
  total             Float
  comisionCalculada Float?         @default(0) @map("comision_calculada")
  metodoPago        String?        @map("metodo_pago") @db.VarChar(255)
  estado            String?        @default("Pagado") @db.VarChar(255)
  createdAt         DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  detalles          VentaDetalle[]
  cliente           Cliente?       @relation(fields: [clienteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendedor          Usuario        @relation(fields: [vendedorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha], map: "idx_ventas_fecha")
  @@index([vendedorId], map: "idx_ventas_vendedor")
  @@map("ventas")
}

model VentaDetalle {
  id             Int      @id @default(autoincrement())
  ventaId        Int      @map("venta_id")
  varianteId     Int      @map("variante_id")
  cantidad       Int
  precioUnitario Float    @map("precio_unitario")
  variante       Variante @relation(fields: [varianteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ventaId], map: "idx_venta_detalles_venta")
  @@map("venta_detalles")
}

model ProductoImagen {
  id            Int       @id @default(autoincrement())
  productoId    Int       @map("producto_id")
  nombreArchivo String    @map("nombre_archivo") @db.VarChar(255)
  ruta          String    @db.VarChar(500)
  publicId      String?   @map("public_id") @db.VarChar(255)
  esPrincipal   Boolean?  @default(false) @map("es_principal")
  orden         Int?      @default(0)
  fechaSubida   DateTime? @default(now()) @map("fecha_subida") @db.Timestamp(6)
  producto      Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([productoId], map: "idx_producto_imagenes_producto")
  @@map("producto_imagenes")
}

enum rol {
  ADMIN
  VENDEDOR
}
