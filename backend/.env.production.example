# controlZapas - Environment Variables Template
# Copiar este archivo como .env y completar los valores

# Server
PORT=3000

# JWT Secret - GENERAR UNO NUEVO PARA PRODUCCIÓN
# Usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Database - Render PostgreSQL
# Formato: postgresql://username:password@host:port/database?schema=public
DATABASE_URL=postgresql://user:password@host:5432/controlzapas

# Cloudinary - Obtener de cloudinary.com
# Formato: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
